    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  e.id::text, \n  e.full_name, \n  e.weekly_hours_target, \n  e.max_daily_hours\nFROM workschedule.employees e\nWHERE e.is_active = true\nORDER BY e.full_name;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        -1472,
        48
      ],
      "id": "411130f7-618e-4c0c-880c-086b952b3900",
      "name": "Obtener empleados"
    },
    {
      "parameters": {
        "jsCode": "const employees = $input.all().map(item => item.json);\nif (employees.length !== 2) {\n  throw new Error(`Se requieren exactamente 2 empleados. Encontrados: ${employees.length}`);\n}\n\n// Calcular lunes de la próxima semana\nconst today = new Date();\nconst nextMonday = new Date(today);\nnextMonday.setDate(today.getDate() + (8 - today.getDay())); // Lunes siguiente\n\nconst dates = [];\nfor (let i = 0; i < 7; i++) {\n  const date = new Date(nextMonday);\n  date.setDate(nextMonday.getDate() + i);\n  dates.push(date.toISOString().split('T')[0]);\n}\n\nreturn [{\n  json: {\n    employees: employees,\n    dates: dates,\n    period: \"next_week\"\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1264,
        48
      ],
      "id": "b6e779bc-54c7-47ae-9e06-fe802416273a",
      "name": "Valida y generar fechas"
    },
    {
      "parameters": {
        "jsCode": "// IDs reales de la BD\nconst juanId = 'c9f87118-d9ce-4e6a-8df3-f0abc9431e2a';\nconst mariaId = '8ffdf02d-9938-4f8d-be81-46980f6377f6';\n\n// Fechas de la próxima semana (lunes a domingo)\nconst today = new Date();\nconst nextMonday = new Date(today.setDate(today.getDate() + (8 - today.getDay())));\nconst dates = Array.from({length: 7}, (_, i) => {\n  const d = new Date(nextMonday);\n  d.setDate(d.getDate() + i);\n  return d.toISOString().split('T')[0];\n});\n\nconst assignments = [];\ndates.forEach((date, idx) => {\n  // Juan libre sábado (día 5), María libre miércoles (día 2)\n  if (idx !== 5) { // Juan trabaja\n    assignments.push({\n      employee_id: juanId,\n      date: date,\n      shift: 'Día',\n      hours: 9, // 9am–6pm = 9 horas\n      start_time: '09:00',\n      end_time: '18:00'\n    });\n  }\n  if (idx !== 2) { // María trabaja\n    assignments.push({\n      employee_id: mariaId,\n      date: date,\n      shift: 'Día',\n      hours: 9,\n      start_time: '09:00',\n      end_time: '18:00'\n    });\n  }\n});\n\nreturn [{ json: { assignments } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1072,
        48
      ],
      "id": "830ca14e-e924-4d4a-b1bc-c42315aba8cf",
      "name": "Aplicar reglas"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO workschedule.schedules \n(user_id, employee_id, schedule_date, start_time, end_time, hours_worked, status)\nVALUES \n{{ $json.assignments.map(a => `\n  (\n    (SELECT id FROM workschedule.users WHERE email = 'gerente@endanus.online'),\n    '${a.employee_id}',\n    '${a.date}',\n    '${a.start_time}:00',\n    '${a.end_time}:00',\n    ${a.hours},\n    'confirmed'\n  )\n`).join(',\\n') }}\nON CONFLICT (employee_id, schedule_date) \nDO UPDATE SET \n  start_time = EXCLUDED.start_time,\n  end_time = EXCLUDED.end_time,\n  hours_worked = EXCLUDED.hours_worked,\n  updated_at = CURRENT_TIMESTAMP\nRETURNING *;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
